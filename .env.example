DISCORD_TOKEN=your_discord_bot_token_here
DEFAULT_GUILD_ID=1493901002519347290

# Optional Grow a Garden 2 stock provider defaults
# The endpoint must be a public HTTPS URL returning JSON. /stock setup can set a per-server URL instead.
GROW_GARDEN_2_STOCK_URL=
GROW_GARDEN_2_STOCK_API_KEY=

# Optional admin web panel
ADMIN_WEB_HOST=0.0.0.0
ADMIN_WEB_PORT=3000
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=http://your_server_ip:3000/auth/discord/callback
SESSION_SECRET=use_a_long_random_secret_here
ADMIN_COOKIE_SECURE=false
