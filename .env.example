DISCORD_TOKEN=your_discord_bot_token_here
# Optional: full YouTube cookie header for play-dl when YouTube blocks VPS playback.
# Prefer ignored file data/youtube-cookies.json for exported YouTube cookie JSON.
# PLAY_DL_YOUTUBE_COOKIE=VISITOR_INFO1_LIVE=...; YSC=...; ...
# Optional: use yt-dlp for YouTube playback when ytdl-core gets HTTP 429.
# YOUTUBE_USE_YT_DLP=1
# YT_DLP_PATH=yt-dlp
